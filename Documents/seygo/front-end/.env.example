# API base URL for local dev. Android emulator uses 10.0.2.2 to reach host.
API_BASE_URL=http://10.0.2.2:8000

# Supabase (optional). Leave placeholders to disable Supabase safely.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Google Maps (optional). Leave blank to hide map preview.
GOOGLE_MAPS_API_KEY=
