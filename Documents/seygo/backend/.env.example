SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_DB_POOLER_URL=postgresql://postgres.your-project-id:your-password@aws-region.pooler.supabase.com:6543/postgres
JWT_SECRET=your-jwt-secret-here
SUPABASE_PLACES_TABLE=placses
SUPABASE_PLACE_PHOTOS_BUCKET=place-photos
SUPABASE_PLACE_PHOTOS_PRIVATE=false
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
# CORS: comma-separated allowed origins (no trailing slash)
# e.g. ALLOWED_ORIGINS=https://yourapp.com,https://yourapp.railway.app
ALLOWED_ORIGINS=http://localhost:3000
# Set to true only if sentence-transformers is installed (uses ~500MB RAM)
SEMANTIC_ENABLED=false
